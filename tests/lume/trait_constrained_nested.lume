-- Tests that constrained impls work with nested types.
-- Show (List (List Num)) uses Show (List a) which uses Show Num.

trait Show a {
  let show : a -> Text
}

use Show in Num {
  let show = n -> showNum n
}

use Show in Show a => List a {
  let show : List a -> Text = xs -> "[" ++ join ", " (map (x -> Show.show x) xs) ++ "]"
}

let _ = Show.show [[1, 2], [3]] |> print
