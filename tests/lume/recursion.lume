-- Tests recursive functions.

let factorial = n ->
  if n <= 1 then 1
  else n * factorial (n - 1)

let _ = factorial 5 |> showNum |> print

let fibonacci = n ->
  if n <= 0 then 0
  else if n == 1 then 1
  else fibonacci (n - 1) + fibonacci (n - 2)

let _ = fibonacci 10 |> showNum |> print

let length : List a -> Num =
  | [] -> 0
  | [_, ..rest] -> 1 + length rest

let _ = length [1, 2, 3, 4, 5] |> showNum |> print
