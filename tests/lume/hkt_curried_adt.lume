-- Tests curried type application for multi-parameter ADTs.
-- Result is a 2-arity constructor: Result a e = Ok a | Err e
-- Ensures that App(App(Con("Result"), Num), Text) works end-to-end.

let safeDivide : Num -> Num -> Result Num Text =
  dividend -> divisor ->
    if divisor == 0
      then Err "division by zero"
      else Ok (dividend / divisor)

let showResult : Result Num Text -> Text =
  | Ok n -> "ok: " ++ showNum n
  | Err msg -> "err: " ++ msg

let _ = safeDivide 10 2 |> showResult |> print
let _ = safeDivide 10 0 |> showResult |> print
