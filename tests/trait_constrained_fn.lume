-- Tests that a polymorphic function with a trait constraint works:
-- the constraint is checked at the call site, not at the definition.
-- Expected output:
--   42

trait Show a {
  let show : a -> Text
}

use Show in Num {
  let show = x -> showNum x
}

let display : (Show a) => a -> Text = x -> Show.show x

let _ = display 42 |> print
