-- Row polymorphism and record operations

let getName = { name, .. } -> name

let alice = { name: "Alice", age: 30, role: "admin" }
let bot   = { name: "R2D2", online: true, version: 3 }

let aliceName = getName alice
let botName   = getName bot

-- Record spread
let aliceWithScore = { ..alice, score: 95 }

let getScore = { score, .. } -> score


pub {
  getName,
  aliceName,
  botName,
  aliceWithScore,
  getScore,
}
