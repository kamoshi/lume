{
  "name": "vscode-lume",
  "displayName": "Lume",
  "description": "Language support for Lume via lume-lsp",
  "version": "0.0.1",
  "publisher": "lume",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:lume"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "lume",
        "extensions": [".lume"],
        "configuration": "./language-configuration.json"
      }
    ],
    "configuration": {
      "title": "Lume",
      "properties": {
        "lume.lsp.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the lume-lsp binary. Leave empty to use PATH."
        }
      }
    }
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "esbuild": "^0.20.0"
  },
  "scripts": {
    "compile": "tsc -p . --noEmit && node esbuild.js",
    "bundle": "node esbuild.js",
    "watch": "node esbuild.js --watch"
  }
}
